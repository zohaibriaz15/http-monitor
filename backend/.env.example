# Server
PORT=4000
NODE_ENV=development

# PostgreSQL connection.
# Either set DATABASE_URL, or the server falls back to libpq defaults (PGHOST, PGUSER, ...).
# On Railway, reference the Postgres plugin: ${{ Postgres.DATABASE_URL }}
DATABASE_URL=postgresql://localhost:5432/http_monitor_development

# Set to true only when connecting to Postgres over a public/SSL endpoint.
# Railway's private networking (the internal DATABASE_URL) does NOT need this.
DATABASE_SSL=false

# Target endpoint to monitor
MONITOR_TARGET_URL=https://httpbin.org/anything

# Cron schedule for the monitor. Default: every 5 minutes.
MONITOR_CRON=*/5 * * * *

# Fire one request immediately on boot instead of waiting for the first cron tick.
MONITOR_RUN_ON_BOOT=true

# Per-request timeout in milliseconds
MONITOR_REQUEST_TIMEOUT_MS=10000

# CORS origin for the frontend (use * in dev; in production set it to the
# deployed frontend URL, e.g. https://your-frontend.up.railway.app)
CORS_ORIGIN=*

# ── Anomaly detection ──
# Rolling-statistics window in hours (1 minimum, 24 recommended).
ANOMALY_WINDOW_HOURS=24
# Z-score / prediction-error threshold in standard deviations (3 ≈ 3-sigma).
ANOMALY_Z_THRESHOLD=3
# EWMA smoothing factor for the forecast (0 < α ≤ 1; higher reacts faster).
ANOMALY_EWMA_ALPHA=0.3
# Minimum prior samples before anomalies are flagged (cold-start guard).
ANOMALY_MIN_SAMPLES=5
