# NOTE: Vite inlines these at BUILD time, so they must be set when `npm run build`
# runs (on Railway, set them as service variables before deploying).
# In production use https / wss and point them at the deployed backend, e.g.
#   VITE_API_BASE=https://your-backend.up.railway.app
#   VITE_WS_URL=wss://your-backend.up.railway.app/ws

# Base URL of the HTTP Monitor backend REST API.
VITE_API_BASE=http://localhost:4000

# WebSocket endpoint for live updates.
VITE_WS_URL=ws://localhost:4000/ws
