{
  "name": "http-monitor-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Real-time dashboard for the HTTP Monitor backend: tabular response history with live WebSocket updates.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "start": "serve -s dist -l tcp://0.0.0.0:${PORT:-4173}",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.62.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.13.3",
    "serve": "^14.2.4"
  },
  "devDependencies": {
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^5.4.11"
  }
}
